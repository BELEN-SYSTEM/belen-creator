{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build",
      "type": "shell",
      "command": "cmd",
      "args": ["/c", "${workspaceFolder}\\scripts\\prepare_installer.bat"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "C:/msys64/ucrt64/bin;${env:PATH}"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Run Belen Creator",
      "type": "shell",
      "command": "${workspaceFolder}/build/BelenCreator.exe",
      "options": {
        "cwd": "${workspaceFolder}/build",
        "env": {
          "PATH": "C:/msys64/ucrt64/bin;${env:PATH}"
        }
      },
      "group": "none",
      "presentation": { "reveal": "always" }
    }
  ]
}
