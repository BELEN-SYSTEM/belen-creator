{
  "version": 3,
  "configurePresets": [
    {
      "name": "mingw",
      "displayName": "Ninja + MSYS2 UCRT64",
      "description": "Requiere: pacman -S mingw-w64-ucrt64-ninja",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "C:/msys64/ucrt64",
        "CMAKE_C_COMPILER": "C:/msys64/ucrt64/bin/gcc.exe",
        "CMAKE_CXX_COMPILER": "C:/msys64/ucrt64/bin/g++.exe",
        "CMAKE_MAKE_PROGRAM": "${sourceDir}/scripts/ninja_preclean.bat"
      }
    }
  ]
}
